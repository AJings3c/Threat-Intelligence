# --- Core ---
PORT=4000
REFRESH_INTERVAL_MS=900000

# Optional: directory for SQLite persistence (first/last-seen, geo cache, trend snapshots).
# Leave empty to run purely in-memory (no persistence). Requires Node >= 22.
DATA_DIR=

# Optional NVD API key. Raises the NVD rate limit from 5 to 50 requests / 30s.
NVD_API_KEY=

# --- Optional social intelligence sources ---
# X Recent Search API. Requires an X developer bearer token.
X_BEARER_TOKEN=
# Defaults to a broad security query when empty.
X_QUERY=
# X recent search allows 10..100 results per request.
X_MAX_RESULTS=25
X_API_BASE=https://api.x.com/2

# Facebook Graph API page posts. Requires a token with access to the target pages.
FACEBOOK_ACCESS_TOKEN=
# Comma-separated page IDs or page usernames to collect.
FACEBOOK_PAGE_IDS=
FACEBOOK_GRAPH_VERSION=v23.0
FACEBOOK_LIMIT=25
FACEBOOK_API_BASE=https://graph.facebook.com

# Optional path to a MaxMind GeoLite2 .mmdb file. When set, IP geolocation is resolved
# offline (no rate limit, no plaintext HTTP). Falls back to ip-api.com when unset/missing.
GEOLITE2_DB=

# Optional API token. When set, every /api route (except /health) requires it via
# Authorization: Bearer <token>, the x-api-token header, or ?token=. Suits machine/SIEM
# access or a private deployment behind a proxy; a browser SPA can't keep it truly secret.
API_TOKEN=

# Frontend API base (leave empty for same-origin / dev proxy)
VITE_API_BASE=
# Token the frontend attaches to API/SSE requests. Set to the same value as API_TOKEN
# when auth is enabled. Note: this is embedded in the built bundle, not a real secret.
VITE_API_TOKEN=

# --- Alerting: scheduled DingTalk / Telegram push ---
# Master switch. Alerts fire only when this is true AND a channel below is configured.
NOTIFY_ENABLED=false
# Digest interval in ms (default 1h).
NOTIFY_INTERVAL_MS=3600000
# Minimum severity to alert on: low | medium | high | critical
NOTIFY_MIN_SEVERITY=critical
# Optional comma list to restrict sources: cisa_kev,feodo,urlhaus,nvd,x,facebook (empty = all)
NOTIFY_SOURCES=
# Max items per digest message.
NOTIFY_MAX_ITEMS=10
# Upper bound on the in-memory de-dup "seen" set (floor 1000). Prevents unbounded growth.
NOTIFY_SEEN_MAX=50000
# Consecutive failed refreshes before a source-health alert fires (floor 1). A recovery
# alert is sent once the source succeeds again. Uses the same channels as digests.
SOURCE_ALERT_THRESHOLD=2
# Token guarding POST /api/notify/test. If set, callers must pass it via the
# x-notify-token header or ?token=. If unset, the endpoint is blocked in production.
NOTIFY_TEST_TOKEN=

# DingTalk custom robot: full webhook URL or just the access_token.
DINGTALK_WEBHOOK=
# Optional signing secret (DingTalk "Signed" security setting). Enables HMAC-SHA256.
DINGTALK_SECRET=

# Telegram bot (from @BotFather) + target chat/group/channel id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack incoming webhook URL (posts the plain-text digest).
SLACK_WEBHOOK=
# Generic webhook URL: receives the digest as JSON { title, text, markdown } for SIEM/automation.
WEBHOOK_URL=
